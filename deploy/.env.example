# ── Context API MCP — environment template ─────────────────────────────
# Copy to .env and fill in. NEVER commit the real .env.

# Base URL of the Context API the MCP proxies to (Docker-internal DNS in prod).
CONTEXT_API_BASE_URL=http://api:8080/api

# Multi-tenant mode: each client sends its own 'Authorization: Bearer eos_...'.
# Leave fallback OFF in production.
ALLOW_FALLBACK_TOKEN=0
# Only used if ALLOW_FALLBACK_TOKEN=1 (single-tenant demo mode).
# CONTEXT_API_TOKEN=eos_...

# Port the MCP server listens on inside the container.
PORT=3000
